# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.test  —  LeafPetals Selenium Test Environment
# Fix: added libvulkan1 + mesa packages required by google-chrome-stable
# ─────────────────────────────────────────────────────────────────────────────

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# ── 1. System packages + libvulkan1 (required by Chrome) ────────────────────
RUN apt-get update && apt-get install -y \
    openjdk-17-jdk \
    maven \
    curl \
    wget \
    unzip \
    gnupg \
    ca-certificates \
    # Chrome dependencies
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    # libvulkan1 fix — pull mesa's vulkan loader directly
    libvulkan1 \
    mesa-vulkan-drivers \
    && rm -rf /var/lib/apt/lists/*

# ── 2. Install Google Chrome stable ─────────────────────────────────────────
RUN wget -q -O /tmp/chrome.deb \
    https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb \
    && apt-get install -y /tmp/chrome.deb \
    && rm /tmp/chrome.deb \
    && rm -rf /var/lib/apt/lists/*

# ── 3. Confirm Chrome installed correctly ───────────────────────────────────
RUN google-chrome --version

# ── 4. Java 17 environment ───────────────────────────────────────────────────
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV PATH="$JAVA_HOME/bin:$PATH"

# ── 5. Working directory & project copy ─────────────────────────────────────
WORKDIR /tests
COPY . .

# Pre-download Maven dependencies to speed up runs
RUN mvn dependency:go-offline -q || true

# ── 6. Run tests (APP_URL injected at runtime by Jenkins) ────────────────────
# NOTE: We use `mvn test` NOT `mvn clean test`
# `clean` tries to delete /tests/target/surefire-reports which is a mounted
# volume owned by the Jenkins host user — this causes a permission error.
# A fresh container already has a clean slate so `clean` is unnecessary.
CMD ["mvn", "test"]
