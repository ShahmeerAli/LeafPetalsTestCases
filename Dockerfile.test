# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.test  —  LeafPetals Selenium Test Environment
#
# WHY NOT markhobson/maven-chrome?
#   That image ships Java 11 but the test code compiles to Java 17,
#   and its ChromeDriver version often mismatches the bundled Chrome binary,
#   causing "session not created / chrome not reachable" at runtime.
#
# THIS IMAGE:
#   - Ubuntu 22.04 base
#   - Java 17 (matches pom.xml compiler target)
#   - Maven 3.9
#   - Google Chrome stable + matching ChromeDriver (managed by WebDriverManager)
# ─────────────────────────────────────────────────────────────────────────────

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# ── 1. System packages ───────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    openjdk-17-jdk \
    maven \
    curl \
    wget \
    unzip \
    gnupg \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# ── 2. Install Google Chrome stable ─────────────────────────────────────────
RUN wget -q -O /tmp/chrome.deb \
    https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb \
    && apt-get install -y /tmp/chrome.deb \
    && rm /tmp/chrome.deb

# ── 3. Java environment ──────────────────────────────────────────────────────
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV PATH="$JAVA_HOME/bin:$PATH"

# ── 4. Working directory ─────────────────────────────────────────────────────
WORKDIR /tests

# Copy the Maven project into the image
COPY . .

# Pre-download all Maven dependencies (speeds up subsequent runs)
RUN mvn dependency:go-offline -q || true

# ── 5. Default command: run the tests ────────────────────────────────────────
# APP_URL is injected at runtime by Jenkins via -e APP_URL=...
CMD ["mvn", "clean", "test", "-Dapp.url=${APP_URL}"]
